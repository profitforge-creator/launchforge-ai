# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic AI (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# App URL (no trailing slash) — set to your Vercel deployment URL in production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# GitHub OAuth App (https://github.com/settings/developers)
GITHUB_CLIENT_ID=Iv1.xxx
GITHUB_CLIENT_SECRET=xxx

# Vercel token for deploy API (https://vercel.com/account/tokens)
VERCEL_TOKEN=xxx

# Secret shared between LaunchForge and integration callbacks
LAUNCHFORGE_INTEGRATION_SECRET=change-me-to-a-random-64-char-string

# ── Diagnostic route protection (optional but strongly recommended in prod) ──
# Generate with: openssl rand -hex 32
# Attach as header: x-internal-secret: <value>
INTERNAL_DIAGNOSTIC_SECRET=

# ── Optional OAuth integrations ───────────────────────────────────────────────

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe OAuth (https://dashboard.stripe.com/settings/connect)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_CLIENT_ID=ca_...
STRIPE_WEBHOOK_SECRET=whsec_...

# TikTok for Developers (https://developers.tiktok.com)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Meta / Facebook (https://developers.facebook.com)
META_CLIENT_ID=
META_CLIENT_SECRET=

# X / Twitter (https://developer.twitter.com)
X_CLIENT_ID=
X_CLIENT_SECRET=

# LinkedIn (https://www.linkedin.com/developers)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
